# The Sparring Room — environment template.
# Copy to .env.local and fill in. NEVER commit .env.local (it is gitignored).

# --- Anthropic (Cloud brain: the Technician + the debrief) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- ElevenLabs (real-time voice: ASR + TTS + turn-taking) ---
ELEVENLABS_API_KEY=...
ELEVENLABS_AGENT_ID=agent_...        # created in the ElevenLabs dashboard (see RUN.md)

# --- Cloud model pinning (env-overridable; see lib/llm.ts) ---
MODEL_ADVERSARY=claude-sonnet-4-6    # fast, for the live call
MODEL_COACH=claude-sonnet-4-6        # post-round debrief (swap to claude-opus-4-8 for max nuance)

# --- Local / Sovereign mode (NVIDIA Nemotron via OpenRouter) ---
# Required only when the Cloud/Local toggle is set to "Local".
OPENROUTER_API_KEY=sk-or-v1-...
MODEL_NEMOTRON=nvidia/nemotron-3-super-120b-a12b:free   # ":free" needs no OpenRouter credits (slower)

# --- Future swaps (not wired yet) ---
# PERPLEXITY_API_KEY=                # Perplexity Sonar — current-topic research
